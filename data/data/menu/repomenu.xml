<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="downloadsmenu">
	<section name="dynamic controls">
		<section name="back">
			<attstr name="type" val="text button"/>
			<attstr name="show box" val="no"/>
			<attstr name="text" val="Back"/>
			<attstr name="tip" val="Back to downloads menu"/>
			<attstr name="h align" val="left"/>
			<attnum name="x" val="190"/>
			<attnum name="y" val="45"/>
			<attnum name="width" val="110"/>
			<attstr name="font" val="big"/>
			<attstr name="color" val="0xa6a6a6"/>
			<attstr name="focused color" val="0xFFFFFF"/>
			<attstr name="pushed color" val="0xFFFFFF"/>
			<attnum name="image x" val="-48"/>
			<attnum name="image y" val="0"/>
			<attnum name="image width" val="160"/>
			<attnum name="image height" val="33"/>
			<attstr name="focused image" val="data/img/bg-button-big-focused.png"/>
			<attstr name="enabled image" val="data/img/bg-button-big.png"/>
			<attstr name="pushed image" val="data/img/bg-button-big-pushed.png"/>
		</section>
		<section name="repos">
			<attstr name="type" val="scroll list"/>
			<attstr name="tip" val="Repository list"/>
			<attnum name="x" val="40"/>
			<attnum name="y" val="120"/>
			<attnum name="width" val="520"/>
			<attnum name="height" val="220"/>
			<attstr name="font" val="medium"/>
			<attstr name="color" val="0xFFFFFF"/>
			<attstr name="selected color" val="0xFF0000"/>
			<attstr name="scrollbar pos" val="right"/>
			<attnum name="image width" val="16"/>
			<attnum name="image height" val="16"/>
		</section>
		<section name="url">
			<attstr name="type" val="edit box"/>
			<attstr name="tip" val="Enter a repository URL"/>
			<attnum name="max len" val="128"/>
			<attnum name="x" val="40"/>
			<attnum name="y" val="90"/>
			<attnum name="width" val="520"/>
			<attstr name="h align" val="left"/>
			<attstr name="font" val="medium"/>
		</section>
		<section name="add">
			<attstr name="type" val="image button"/>
			<attstr name="tip" val="Add a new repository"/>
			<attnum name="x" val="300"/>
			<attnum name="y" val="45"/>
			<attnum name="width" val="49"/>
			<attnum name="height" val="33"/>
			<attstr name="disabled image" val="data/img/icon-new-disabled.png"/>
			<attstr name="enabled image" val="data/img/icon-new.png"/>
			<attstr name="focused image" val="data/img/icon-new-focused.png"/>
			<attstr name="pushed image" val="data/img/icon-new-pushed.png"/>
		</section>
		<section name="delete">
			<attstr name="type" val="image button"/>
			<attstr name="tip" val="Delete selected repository"/>
			<attnum name="x" val="350"/>
			<attnum name="y" val="45"/>
			<attnum name="width" val="49"/>
			<attnum name="height" val="33"/>
			<attstr name="disabled image" val="data/img/icon-delete-disabled.png"/>
			<attstr name="enabled image" val="data/img/icon-delete.png"/>
			<attstr name="focused image" val="data/img/icon-delete-focused.png"/>
			<attstr name="pushed image" val="data/img/icon-delete-pushed.png"/>
		</section>
	</section>
	<section name="static controls">
		<section name="1">
			<attstr name="type" val="static image"/>
			<attnum name="x" val="-10"/>
			<attnum name="y" val="375"/>
			<attnum name="width" val="130"/>
			<attnum name="height" val="95"/>
			<attstr name="image" val="data/img/sd-logo-big.png"/>
		</section>
		<section name="2">
			<attstr name="type" val="background image"/>
			<attstr name="image" val="data/img/splash-networkclient.jpg"/>
		</section>
		<section name="3">
			<attstr name="type" val="label"/>
			<attstr name="text" val="Repository manager"/>
			<attnum name="x" val="300"/>
			<attnum name="y" val="430"/>
			<attnum name="width" val="400"/>
			<attstr name="color" val="0xFFFFFF"/>
			<attstr name="font" val="medium_t"/>
			<attstr name="h align" val="left"/>
			<attstr name="bg image" val="data/img/header-background.png"/>
			<attnum name="bg image padding top" val="15"/>
			<attnum name="bg image padding bottom" val="15"/>
			<attnum name="bg image padding left" val="30"/>
			<attnum name="bg image padding right" val="15"/>
		</section>
		<section name="4">
			<attstr name="type" val="label"/>
			<attnum name="x" val="40"/>
			<attnum name="y" val="350"/>
			<attstr name="text" val="Configured repositories:"/>
			<attstr name="h align" val="left"/>
			<attnum name="width" val="200"/>
			<attstr name="font" val="big"/>
			<attstr name="color" val="0xFFFFFF"/>
		</section>
	</section>
</params>
