<!--

	Normal race screen (real-time animated virtual 3D world)

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="raceglscreen">
  <section name="dynamic controls">
    <section name="message">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="64"/>
      <attnum name="x" val="20"/>
      <attnum name="y" val="420"/>
      <attnum name="width" val="600"/>
      <attstr name="h align" val="center"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="large_c"/>
    </section>
    <section name="bigmessage">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="32"/>
      <attnum name="x" val="20"/>
      <attnum name="y" val="360"/>
      <attnum name="width" val="600"/>
      <attstr name="h align" val="center"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="large_c"/>
    </section>
    <section name="pause">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Game Paused"/>
      <attnum name="x" val="20"/>
      <attnum name="y" val="250"/>
      <attnum name="width" val="600"/>
      <attstr name="h align" val="center"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="big_c"/>
      <attstr name="bg image" val="data/img/label-bg.png"/>
      <attnum name="bg image padding top" val="15"/>
      <attnum name="bg image padding bottom" val="15"/>
      <attnum name="bg image padding left" val="15"/>
      <attnum name="bg image padding right" val="15"/>
    </section>
  </section>
  <section name="static controls">

  </section>
  <section name="music">
    <attstr name="music file" val="None"/>
  </section>
</params>
