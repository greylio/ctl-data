    <section name="trackcatleftarrow">
      <attstr name="type" val="image button"/>
      <attnum name="x" val="265"/>
      <attnum name="y" val="318"/>
      <attnum name="width" val="24"/>
      <attnum name="height" val="25"/>
      <attstr name="disabled image" val="data/img/arrow-left-top-disabled.png"/>
      <attstr name="enabled image" val="data/img/arrowleft-normal.png"/>
      <attstr name="focused image" val="data/img/arrowleft-focused.png"/>
      <attstr name="pushed image" val="data/img/arrowleft-pushed.png"/>
    </section>
    <section name="trackcatrightarrow">
      <attstr name="type" val="image button"/>
      <attnum name="x" val="525"/>
      <attnum name="y" val="318"/>
      <attnum name="width" val="24"/>
      <attnum name="height" val="25"/>
